# ===========================================================================
# 로컬 개발용 환경변수 샘플. 이 파일을 `.env`로 복사해 값을 채운다.
#   PowerShell:  Copy-Item .env.example .env
# `.env`는 .gitignore에 포함 — 절대 커밋하지 않는다.
# 프로덕션(Lambda)은 이 값들을 AWS Secrets Manager(SECRETS_NAME) JSON에 넣는다.
# ===========================================================================

# --- 실행 환경 ---
LOCAL_DEV=true                          # true → .env 로드 / false(Lambda) → Secrets Manager
SECRETS_NAME=naver-review/production    # Secrets Manager 시크릿 이름(프로덕션 로드 대상)
DYNAMO_TABLE_PREFIX=dev_                # 로컬 dev_ / 프로덕션 prod_ (테이블명 접두사)

# --- Telegram (BotFather에서 발급) ---
TELEGRAM_BOT_TOKEN=                     # @BotFather /newbot 으로 발급받은 봇 토큰
TELEGRAM_CHAT_IDS=["123456789"]         # 허용 사용자 chat_id 목록(JSON 배열). 이 목록 외 요청은 무시
TELEGRAM_DEVELOPER_CHAT_ID=             # 에러 알림을 받을 개발자 chat_id(단일 값)
TELEGRAM_WEBHOOK_SECRET=                # setWebhook의 secret_token과 동일하게 설정(무단 호출 차단)

# --- Claude (Anthropic) ---
ANTHROPIC_API_KEY=                      # 리뷰 요약용 Claude API 키(없으면 요약 생략, 원문만 응답)
