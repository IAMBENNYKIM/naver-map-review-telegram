# ---------------------------------------------------------------------------
# 시크릿 (config._SECRET_KEYS 와 정확히 일치 — Secrets Manager JSON 키와 동일)
# ---------------------------------------------------------------------------
# Telegram 봇 토큰 (@BotFather 발급)
TELEGRAM_BOT_TOKEN=

# 허용 chat_id 목록 (JSON 배열 문자열, 예: ["123456789","987654321"])
TELEGRAM_CHAT_IDS=[]

# 에러 알림을 받을 개발자 chat_id
TELEGRAM_DEVELOPER_CHAT_ID=

# Webhook 검증용 secret token (setWebhook의 secret_token과 동일 값)
TELEGRAM_WEBHOOK_SECRET=

# Claude API 키 (리뷰 분석)
ANTHROPIC_API_KEY=

# ---------------------------------------------------------------------------
# 로컬 환경변수 (Lambda에서는 template.yaml이 주입)
# ---------------------------------------------------------------------------
# true 면 .env 로드, 아니면 Secrets Manager 사용
LOCAL_DEV=true

# Secrets Manager 시크릿 이름 (프로덕션 전용)
SECRETS_NAME=naver-review/production

# DynamoDB 테이블 접두사 (로컬 dev_ / 프로덕션 prod_)
DYNAMO_TABLE_PREFIX=dev_

# AWS 리전
AWS_DEFAULT_REGION=ap-northeast-2

# WorkerFunction 함수명 (WebhookFunction이 비동기 invoke할 대상)
WORKER_FUNCTION_NAME=naver-review-worker
